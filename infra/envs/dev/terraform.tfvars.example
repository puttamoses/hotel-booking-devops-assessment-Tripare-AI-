# Copy to terraform.tfvars for local plan review, or rely on the defaults in
# variables.tf and just supply db_password. Never commit a real password --
# use TF_VAR_db_password instead.

aws_region   = "ap-south-1"
project_name = "hotel-booking"
environment  = "dev"

db_engine                  = "postgres"
db_instance_class          = "db.t3.micro"
db_backup_retention_period = 3
db_deletion_protection     = false
db_multi_az                = false

# db_password = "set via TF_VAR_db_password instead"
